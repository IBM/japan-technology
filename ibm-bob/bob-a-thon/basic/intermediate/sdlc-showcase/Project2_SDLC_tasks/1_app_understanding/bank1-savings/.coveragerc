# Coverage configuration for Bank1-Savings

[run]
source = .
omit =
    test_*.py
    *_test.py
    */tests/*
    */venv/*
    */env/*
    */frontend/*
    setup.py

[report]
precision = 2
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov
title = Bank1-Savings Test Coverage Report