# Make sure to get the correct URL, including the base URL, instance id, and agent id
AGENT_URL = "https://api.dl.watson-orchestrate.ibm.com/instances/YOUR_INSTANCE_ID/v1/orchestrate/YOUR_AGENT_ID/chat/completions"

# API key
WXO_API_KEY = "your_aws_api_key_here"

# Cloud provider: ibm or aws
CLOUD_PROVIDER="aws"

# These values should work for all WxO instances
IBM_AUTH_ENDPOINT="https://iam.cloud.ibm.com/identity/token"
AWS_AUTH_ENDPOINT="https://iam.platform.saas.ibm.com/siusermgr/api/1.0/apikeys/token"